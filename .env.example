# FormOlusturma — Konfigürasyon Şablonu
# Dosya: .env (varsa) veya default değerleri kullan

# ─────────────────────────────────────
# Veritabanı
# ─────────────────────────────────────

# Veritabanı dosya yolu (opsiyonel)
# DATABASE_PATH=veri/proje_yonetimi.db

# ─────────────────────────────────────
# Uygulama
# ─────────────────────────────────────

# Uygulama başlangıçta debug modu (opsiyonel)
# DEBUG=False

# Log seviyesi: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# ─────────────────────────────────────
# Google Drive Entegrasyonu
# ─────────────────────────────────────

# Google credentials JSON (geçerli olabilir)
# GOOGLE_CREDENTIALS_FILE=credentials.json

# ─────────────────────────────────────
# UI / Görünüm
# ─────────────────────────────────────

# Pencere başlangıç boyutu (genişlik x yükseklik)
# WINDOW_SIZE=1600x900

# Tema: Fusion, WindowsVista, vb.
# UI_STYLE=Fusion

# ─────────────────────────────────────
# Varsayılan İçerik
# ─────────────────────────────────────

# İlk admin kullanıcı şifresi (ilk çalıştırmada)
# DEFAULT_ADMIN_PASSWORD=admin123

# Varsayılan para birimi
# DEFAULT_CURRENCY=TRY

# Varsayılan KDV oranı (%)
# DEFAULT_VAT_RATE=20

# ─────────────────────────────────────
# Senkronizasyon
# ─────────────────────────────────────

# Google Drive senkronizasyon etkindir
# ENABLE_DRIVE_SYNC=True

# Senkronizasyon interval (saniye)
# SYNC_INTERVAL=300

# ─────────────────────────────────────
# Güvenlik
# ─────────────────────────────────────

# Oturum timeout (dakika)
# SESSION_TIMEOUT=60

# Şifre minimum uzunluğu
# MIN_PASSWORD_LENGTH=8

# ─────────────────────────────────────
# Performans
# ─────────────────────────────────────

# Veritabanı bağlantı pooling (gelecek versiyon)
# DB_POOL_SIZE=5

# Cache TTL (saniye)
# CACHE_TTL=3600

# ─────────────────────────────────────
# Notlar
# ─────────────────────────────────────
# - Bu dosya .env olarak kaydedilirse sistem yüklenecek
# - Default değerler README.md'de belirtilmiştir
# - Üretim ortamı için env değişkenlerini güvenli tutun
